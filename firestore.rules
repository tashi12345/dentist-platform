rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /appointments/{document} {
      allow create: if true;
      // DEMO MODE: Allow reading all appointments without authentication
      // For production, restore: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.email == request.auth.token.email));
      allow read: if true;
      // DEMO MODE: Allow updating/deleting all appointments without authentication
      // For production, restore: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if true;
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.role == "user";
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /contactMessages/{document} {
      allow create: if true;
      // DEMO MODE: Allow reading/updating messages without authentication
      // For production, restore: if isAdmin();
      allow read, update, delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
